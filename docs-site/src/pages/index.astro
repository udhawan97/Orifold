---
/**
 * Orifold landing — "One sheet, folded into flight."
 * A washi-paper page in five quiet acts around the fold: the hero (the crane,
 * folding), calm-by-architecture (the promise), one-workspace/every-fold
 * (surfaces), see-it-on-your-desktop (real product shots), and a deep-sumi act
 * for privacy + the two paper companions, then the download close.
 *
 * Fixed brand scheme (washi light + one sumi band), Shippori-Mincho display,
 * one vermilion (朱) accent, faint origami kanji throughout. Motion is
 * transform/opacity only and settles fully under prefers-reduced-motion.
 * Inspired by the calm of a well-made print page — origami, not a copy.
 */
import '../styles/landing-washi.css';
import site from '../data/site.json';
import stats from '../data/stats.json';
import { getRelease } from '../lib/release';
import craneFold from '../assets/orifold-crane-fold.svg?raw';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rel = await getRelease();

const downloadHref = rel.dmgMissing ? rel.zipUrl : rel.dmgUrl;
const assetKind = rel.dmgMissing ? '.zip' : '.dmg';
const sizePart = rel.dmgSize ? ` · ${rel.dmgSize}` : '';
const subLabel = `macOS ${site.minMacOS}+ · ${site.arch}${sizePart}`;

const cap = (name: string, dir: 'screenshots' | 'gifs' | 'landing' = 'screenshots') => `${base}/assets/${dir}/${name}`;

// The workspace, six surfaces — each with a faint origami kanji watermark.
const surfaces = [
	{ kanji: '束', name: 'Assemble', body: 'Drag up to fifty PDFs, Word files, images, and scans into one calm stack — broken PDFs repaired on the way in.', href: 'import/combine/' },
	{ kanji: '直', name: 'Edit', beta: true, body: 'Fix the real glyphs and page objects, not a sticky note over a picture. Move, restyle, and delete what is actually there.', href: 'edit/edit-objects/' },
	{ kanji: '印', name: 'Sign', body: 'A drawn mark is a picture; a PAdES digital signature is math — a tamper-evident seal over the exact bytes you signed.', href: 'fill-sign/signatures/' },
	{ kanji: '読', name: 'Search', body: 'On-device Vision OCR makes a scan searchable, so ⌘F finally finds the thing your printer emailed you.', href: 'edit/ocr/' },
	{ kanji: '守', name: 'Protect', body: 'Real AES-256 encryption, plus a sanitize pass that strips auto-run actions, embedded scripts, and hidden metadata.', href: 'export/protect/' },
	{ kanji: '語', name: 'Speak', body: 'The whole workspace — menus to tooltips — in English, Spanish, French, Hindi, Simplified Chinese, and Japanese.', href: 'settings/language/' },
];

// Calm-by-architecture — three notes, three kanji.
const notes = [
	{ kanji: '家', n: '01', t: 'On your Mac, only', p: 'Import, OCR, compression, encryption, signing, and export never touch a network. There is no server to send anything to.' },
	{ kanji: '実', n: '02', t: 'Real, not a picture', p: 'Orifold edits the actual page geometry and produces standards-based signatures — not annotations floating over a flat image.' },
	{ kanji: '開', n: '03', t: 'Free & open source', p: 'No account, no upload, no subscription. Apache-2.0 licensed and built in the open, one honest fold at a time.' },
];

const numbers = [
	{ b: '0', s: 'Times your files are uploaded. The cloud is never consulted.', accent: true },
	{ b: 'AES-256', s: 'Real encryption — not a "protected" flag a reader can ignore.' },
	{ b: String(stats.tests ?? '700+'), s: 'Tests gate every release before it ships.' },
	{ b: '6', s: 'Languages, everything on-device.' },
	{ b: '50', s: 'Files can fold into one workspace at a time.' },
	{ b: '$0', s: 'Forever. Apache-2.0, free and open source.' },
];

// ── inline glyphs ─────────────────────────────────────────────
const icoApple = '<svg viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M11.182.008C11.148-.03 9.923.023 8.857 1.18c-1.066 1.156-.902 2.482-.878 2.516.024.034 1.52.087 2.475-1.258.955-1.345.762-2.391.728-2.43zm3.314 11.733c-.048-.096-2.325-1.234-2.113-3.422.212-2.189 1.675-2.789 1.698-2.854.023-.065-.597-.79-1.254-1.157a3.7 3.7 0 0 0-1.563-.434c-.108-.003-.483-.095-1.254.116-.508.139-1.653.589-1.968.607-.316.018-1.256-.522-2.267-.665-.647-.125-1.333.131-1.824.328-.49.196-1.422.754-2.074 2.237-.652 1.482-.311 3.83-.067 4.56s.625 1.924 1.273 2.796c.576.984 1.34 1.667 1.659 1.899.319.232 1.219.386 1.843.067.502-.308 1.408-.485 1.766-.472.357.013 1.061.154 1.782.539.571.197 1.111.115 1.652-.105.541-.221 1.324-1.059 2.238-2.758.347-.79.505-1.217.473-1.282z"/></svg>';
const icoBook = '<svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1.05rem;height:1.05rem"><path d="M10 5.4C8.6 4.1 6.2 3.9 4 4.4v10.8c2.2-.5 4.6-.3 6 1 1.4-1.3 3.8-1.5 6-1V4.4c-2.2-.5-4.6-.3-6 1Zm0 0v11.8"/></svg>';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
		<meta name="theme-color" content="#f4f1e8" />
		<title>Orifold — One sheet, folded into flight</title>
		<meta
			name="description"
			content="A calm, local-first PDF workspace for macOS. Drop in up to 50 messy files — merge, edit, OCR, sign, and protect them — and fold the pile into one clean document. Nothing leaves your Mac."
		/>
		<meta property="og:title" content="Orifold — One sheet, folded into flight" />
		<meta property="og:description" content="A calm, local-first PDF workspace for macOS. Free, open source, and entirely on-device." />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap"
		/>
		<script is:inline>
			// Pre-paint: mark JS present (so the animated fold shows instead of the static
			// poster), gate reduced-motion, and detect non-Mac so the CTA never flashes.
			(function () {
				var d = document.documentElement;
				d.classList.add('js');
				try {
					if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) d.classList.add('no-motion');
				} catch (e) {}
				try {
					var p = (navigator.userAgentData && navigator.userAgentData.platform) || navigator.platform || '';
					var isMac = /mac/i.test(p) && !(navigator.maxTouchPoints > 1);
					if (!isMac) d.classList.add('not-mac');
				} catch (e) {}
			})();
		</script>
	</head>
	<body data-repo-url={site.repoUrl}>
		<a class="skip-link" href="#promise">Skip to content</a>
		<div class="route-progress" aria-hidden="true"></div>

		<header class="topbar">
			<a class="brandline" href={`${base}/`} aria-label="Orifold home">
				<img src={`${base}/assets/orifold-app-icon-32.png`} alt="" width="30" height="30" />
				<span class="brandword">ORIFOLD</span>
			</a>
			<nav aria-label="Primary">
				<a class="only-wide" href="#surfaces">Features</a>
				<a href={`${base}/get-started/what-is-orifold/`}>Docs</a>
				<a href={site.repoUrl}>GitHub</a>
				<a class="nav-dl" href={downloadHref}>Download</a>
			</nav>
		</header>

		<main>
			<!-- Act I · the fold -->
			<section class="hero">
				<div class="hero-copy">
					<p class="eyebrow" data-load="1">PDF workspace <span class="en">·</span> macOS</p>
					<h1 aria-label="One sheet, folded into flight.">
						<span class="hl" data-load="2"><span>One sheet, folded</span></span>
						<span class="hl" data-load="3"><span>into <em>flight</em>.</span></span>
					</h1>
					<p class="lede" data-load="4">
						A calm, local-first PDF workspace for macOS. Drop in up to fifty messy files —
						merge, edit, OCR, sign, and protect them — and fold the pile into{' '}
						<strong>one clean document</strong>. Nothing leaves your Mac.
					</p>
					<div class="actions" data-load="5">
						<a class="primary" id="cta-hero" href={downloadHref}>
							<span class="p-main"><Fragment set:html={icoApple} /><span class="mac-only">Download for Mac</span><span class="not-mac-only" hidden>View on GitHub</span></span>
							<span class="p-sub">{subLabel}</span>
						</a>
						<a class="ghost" href={`${base}/get-started/what-is-orifold/`}><Fragment set:html={icoBook} />Read the docs</a>
					</div>
					<p class="hero-meta" data-load="6">
						<span class="m">v{rel.version}</span>
						<span class="m">Universal · Apple Silicon + Intel</span>
						<span class="m">Apache-2.0</span>
						<span class="m">Beta</span>
					</p>
					<p class="inoc mac-only">
						Not notarized yet — first launch takes one calm step. <a href="#take-flight">Here's how →</a>
					</p>
				</div>

				<figure class="hero-panel" data-load="3" aria-label="Orifold app mark">
					<figcaption class="cap"><b>折</b> · ONE SHEET, FOLDED</figcaption>
					<div class="crane-art" id="hero-crane">
						<div class="crane-anim" set:html={craneFold}></div>
						<img class="crane-poster" src={`${base}/assets/orifold-app-icon-512.png`} width="512" height="512" alt="" aria-hidden="true" />
					</div>
					<div class="panel-word">ORIFOLD</div>
				</figure>

				<div class="kanji-rail mincho" aria-hidden="true">折　鶴　間　朱</div>
				<a class="scroll-cue" href="#promise" aria-label="Scroll to content"><span></span></a>
			</section>

			<!-- Act II · the promise -->
			<section class="promise" id="promise" aria-labelledby="promise-title">
				<div class="shead" data-reveal>
					<p class="eyebrow">The idea</p>
					<h2 id="promise-title">Calm by architecture.<br />Not by accident.</h2>
				</div>
				<div class="notes">
					{notes.map((note, i) => (
						<article class="note" data-reveal style={`--d:${i}`}>
							<div class="kanji mincho" aria-hidden="true">{note.kanji}</div>
							<h3><span class="nnum">{note.n}</span>{note.t}</h3>
							<p>{note.p}</p>
						</article>
					))}
				</div>
			</section>

			<!-- Act III · the workspace, six surfaces -->
			<section class="surfaces" id="surfaces" aria-labelledby="surfaces-title">
				<div class="shead" data-reveal>
					<p class="eyebrow">The workspace</p>
					<h2 id="surfaces-title">One workspace. Every fold.</h2>
					<p class="shead-sub">Twelve tools that used to mean five apps and a print-sign-scan loop — merge, edit, sign, search, protect — in one calm, native window.</p>
				</div>
				<div class="tiles">
					{surfaces.map((s, i) => (
						<a class="tile" href={`${base}/${s.href}`} data-reveal style={`--d:${i}`}>
							<div class="tile-kanji mincho" aria-hidden="true">{s.kanji}</div>
							<span class="tile-dot" aria-hidden="true" />
							<h3><span class="nnum">0{i + 1}</span>{s.name}{s.beta && <span class="beta">beta</span>}</h3>
							<p>{s.body}</p>
						</a>
					))}
				</div>
				<p class="guides-row" data-reveal>
					More folds: <a href={`${base}/annotate/stamps/`}>Stamps &amp; Bates</a> · <a href={`${base}/export/compress/`}>Compress</a> · <a href={`${base}/fill-sign/forms/`}>Forms</a> · <a href={`${base}/reading/reader-mode/`}>Reader mode</a>.
				</p>
			</section>

			<!-- Act IV · see it on your desktop (real captures) -->
			<section class="showcase" aria-labelledby="showcase-title">
				<div class="shead" data-reveal>
					<p class="eyebrow">Not a render</p>
					<h2 id="showcase-title">See it on your desktop.</h2>
					<p class="shead-sub">Real captures of Orifold {`v${rel.version}`} — a native Mac window, not a mockup.</p>
				</div>
				<figure class="shot" data-reveal>
					<div class="frame wide">
						<img src={cap('the-orifold-window-annotated.png')} width="1600" height="1000" loading="lazy" decoding="async" alt="The Orifold workspace: a document sidebar, a PDF open on the canvas, a floating markup toolbar, and the paper companion in the corner." />
					</div>
					<figcaption><b>The workspace.</b> Sidebar, canvas, markup toolbar, and your paper companion — all on your Mac.</figcaption>
				</figure>
				<div class="shot-grid">
					<figure class="shot" data-reveal style="--d:0">
						<div class="frame">
							<img src={cap('edit-text-workflow.png')} width="1600" height="1000" loading="lazy" decoding="async" alt="Orifold editing real PDF text in place, with a floating format toolbar." />
						</div>
						<figcaption><b>Edit the page itself.</b> Real glyphs, not a note stuck on top.</figcaption>
					</figure>
					<figure class="shot" data-reveal style="--d:1">
						<div class="frame">
							<img src={cap('night-mode-comparison.png')} width="1600" height="1000" loading="lazy" decoding="async" alt="Orifold's Night Mode shown beside the default view, dimming a document for comfortable reading." />
						</div>
						<figcaption><b>Read, day or night.</b> Reader Mode and warm Night Mode presets.</figcaption>
					</figure>
				</div>
			</section>

			<!-- Act V · deep sumi — privacy + the paper companions -->
			<section class="sumi" aria-labelledby="privacy-title">
				<div class="sumi-inner">
					<div class="shead" data-reveal>
						<p class="eyebrow">Privacy, by architecture</p>
						<h2 id="privacy-title">Nothing leaves your Mac.</h2>
						<p class="shead-sub">
							Local-first is not a setting here — it's the architecture. The app runs in the macOS
							sandbox with access only to the files you choose. The one network request it can make
							is an opt-in, off-by-default check for a newer version — never anything about you or
							your documents. <a href={`${base}/settings/privacy/`}>Read the privacy model →</a>
						</p>
					</div>
					<div class="numbers" data-reveal>
						{numbers.map((num) => (
							<div class={`num${num.accent ? ' accent' : ''}`}>
								<b set:html={num.b} />
								<span>{num.s}</span>
							</div>
						))}
					</div>

					<div class="companions" aria-labelledby="companions-title">
						<div class="shead" data-reveal style="margin-bottom:0">
							<p class="eyebrow">Folded to keep you company</p>
							<h2 id="companions-title">Two paper companions.</h2>
						</div>
						<div class="comp-grid">
							<div class="comp" data-reveal style="--d:0">
								<span class="fig"><img src={`${base}/assets/gami-figure.svg`} width="68" height="68" alt="Gami, the origami dog" /></span>
								<div>
									<h3>Gami<span class="s">· the dog</span></h3>
									<p>A calm paper companion — your everyday guide. Shows up when something needs you, then folds back into the corner.</p>
								</div>
							</div>
							<div class="comp" data-reveal style="--d:1">
								<span class="fig"><img src={`${base}/assets/ori-figure.svg`} width="68" height="68" alt="Ori, the origami cat" /></span>
								<div>
									<h3>Ori<span class="s">· the cat</span></h3>
									<p>Clever and a touch bossy. She watches the technical corners: signing, privacy, and the fine print.</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<!-- Close · take flight -->
			<section class="close-band" id="take-flight" aria-labelledby="close-title">
				<img class="close-fold" src={`${base}/assets/orifold-app-icon-512.png`} width="512" height="512" loading="lazy" decoding="async" alt="" aria-hidden="true" />
				<div class="close-word mincho">Orifold</div>
				<div class="close-tag">One sheet, folded into flight</div>
				<h2 id="close-title" class="sr-only">Take it home</h2>
				<div class="actions">
					<a class="primary" id="cta-final" href={downloadHref}>
						<span class="p-main"><Fragment set:html={icoApple} /><span class="mac-only">Download for Mac</span><span class="not-mac-only" hidden>View on GitHub</span></span>
						<span class="p-sub">{assetKind} · v{rel.version}{sizePart}</span>
					</a>
					<a class="ghost" href={`${base}/get-started/what-is-orifold/`}><Fragment set:html={icoBook} />Read the docs</a>
				</div>
				<p class="close-note mac-only">
					Free and open source, so builds aren't notarized by Apple yet. First launch: <b>right-click Orifold → Open → Open</b>. Prefer zero dialogs? Install with Homebrew — it clears Gatekeeper for you.
				</p>
				<div class="chip-cmd">
					<code>brew install --cask orifold</code>
					<button type="button" class="copy-btn" data-copy="brew install --cask orifold" aria-label="Copy Homebrew command">Copy</button>
				</div>
			</section>
		</main>

		<footer>
			<p>Folded by hand · Apache-2.0</p>
			<nav aria-label="Footer">
				<a href={`${base}/get-started/what-is-orifold/`}>Docs</a>
				<a href={`${base}/releases/`}>What's new</a>
				<a href={`${base}/settings/privacy/`}>Privacy</a>
				<a href={site.repoUrl}>GitHub</a>
				<a href={rel.releaseUrl}>v{rel.version}</a>
			</nav>
			<div class="palette" aria-hidden="true">
				<span title="Washi #F4F1E8" style="background:#f4f1e8"></span>
				<span title="Sumi #1B1A17" style="background:#1b1a17"></span>
				<span title="Ai indigo #2B4566" style="background:#2b4566"></span>
				<span title="Shu vermilion #C1442F" style="background:#c1442f"></span>
				<span title="Silver #A9A69C" style="background:#a9a69c"></span>
			</div>
		</footer>

		<script is:inline>
			(function () {
				var d = document.documentElement;
				var reduce = d.classList.contains('no-motion');

				// ── non-Mac CTA swap (label already gated by CSS; toggle hidden + href) ──
				if (d.classList.contains('not-mac')) {
					var repoUrl = (document.body && document.body.dataset.repoUrl) || '';
					['cta-hero', 'cta-final'].forEach(function (id) {
						var a = document.getElementById(id);
						if (!a) return;
						if (repoUrl) a.setAttribute('href', repoUrl);
						var mac = a.querySelector('.mac-only');
						var nm = a.querySelector('.not-mac-only');
						if (mac) mac.setAttribute('hidden', '');
						if (nm) nm.removeAttribute('hidden');
					});
				}

				// ── scroll reveals ──
				var revealed = document.querySelectorAll('[data-reveal]');
				if (reduce || !('IntersectionObserver' in window)) {
					revealed.forEach(function (el) { el.classList.add('in'); });
				} else {
					var io = new IntersectionObserver(function (entries) {
						entries.forEach(function (e) {
							if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
						});
					}, { threshold: 0.16, rootMargin: '0px 0px -8% 0px' });
					revealed.forEach(function (el) { io.observe(el); });
				}

				// ── route-progress thread (reader-drawn) ──
				var thread = document.querySelector('.route-progress');
				var raf = 0;
				function draw() {
					raf = 0;
					if (!thread) return;
					var doc = document.documentElement;
					var max = doc.scrollHeight - doc.clientHeight;
					thread.style.transform = 'scaleX(' + (max > 0 ? doc.scrollTop / max : 0) + ')';
				}
				addEventListener('scroll', function () { if (!raf) raf = requestAnimationFrame(draw); }, { passive: true });
				draw();

				// ── the fold: play once, then settle on the held crane pose ──
				// The crane-fold SVG loops indefinitely; snap it to its crown-visible
				// held pose (~3.2s) and freeze, so the hero rests calm rather than
				// folding on forever. Poll the SVG's own clock (robust under load).
				var crane = document.getElementById('hero-crane');
				var svg = crane && crane.querySelector('.crane-anim svg');
				if (svg && svg.pauseAnimations) {
					var SETTLE = 3.2, done = false;
					var settle = function () {
						if (done) return;
						try {
							if (svg.getCurrentTime() !== SETTLE) svg.setCurrentTime(SETTLE);
							svg.pauseAnimations();
						} catch (e) { return; }
						done = true;
						var art = crane.querySelector('.crane-art') || crane;
						art.classList.add('crane-float');
					};
					if (reduce) { settle(); }
					else {
						(function watch() {
							if (done) return;
							try { if (svg.getCurrentTime() >= SETTLE) { settle(); return; } } catch (e) { return; }
							requestAnimationFrame(watch);
						})();
						document.addEventListener('visibilitychange', function () { if (!document.hidden) settle(); });
					}
				}

				// ── copy the brew command ──
				var copyBtn = document.querySelector('.copy-btn');
				if (copyBtn && navigator.clipboard) {
					copyBtn.addEventListener('click', function () {
						navigator.clipboard.writeText(copyBtn.getAttribute('data-copy') || '').then(function () {
							var t = copyBtn.textContent;
							copyBtn.textContent = 'Copied';
							setTimeout(function () { copyBtn.textContent = t; }, 1600);
						});
					});
				}
			})();
		</script>
	</body>
</html>
