<script>
	// SMIL animation tags don't respect prefers-reduced-motion on their own —
	// pause the crane fold explicitly when the user has asked for less motion.
	const crane = document.getElementById('of-hero-crane');
	if (crane instanceof HTMLObjectElement && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
		crane.addEventListener('load', () => {
			const svg = crane.contentDocument?.documentElement;
			if (svg instanceof SVGSVGElement) svg.pauseAnimations();
		});
	}
</script>
